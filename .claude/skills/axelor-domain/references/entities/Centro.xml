<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="common" package="com.educaflow.subsystem.common.db"/>
    <entity name="Centro">

        <many-to-one name="imagenSello" ref="com.axelor.meta.db.MetaFile" title="Sello"/>

        <many-to-one name="administrador" ref="com.axelor.auth.db.User" title="Administrador del centro"/>
        <one-to-many name="usuarios" ref="com.educaflow.subsystem.security.db.CentroUsuario" mappedBy="centro" title=""/>

        <many-to-one name="importarProfesores" ref="com.axelor.meta.db.MetaFile" title="Importar profesores" transient="true"/>
        <many-to-one name="importarAlumnos" ref="com.axelor.meta.db.MetaFile" title="Importar alumnos" transient="true"/>

        <string name="code" title="Código" required="true" unique="true" />
        <string name="name" title="Nombre" namecolumn="true" required="true"/>
        <string name="direccion" title="Dirección"/>
        <string name="codigoPostal" title="Código Postal"/>
        <many-to-one name="municipio"   title="Municipio"   ref="Municipio" required="true"/>
        <many-to-one name="conselleria" title="Conselleria" ref="Municipio" required="true"/>
        <integer name="curso" title="Curso académico" help="Ejemplo: 2024"/>
    </entity>

</domain-models>