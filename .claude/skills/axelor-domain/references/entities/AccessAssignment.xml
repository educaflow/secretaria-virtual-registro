<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="security" package="com.educaflow.subsystem.security.db"/>
    <entity name="AccessAssignment">
        <many-to-one name="actor" ref="com.educaflow.subsystem.security.db.SecurityActor" required="true" title="Actor"/>
        <many-to-one name="accessProfile" ref="com.educaflow.subsystem.security.db.AccessProfile" required="true" title="Perfil"/>
        <many-to-one name="tramite" ref="com.educaflow.subsystem.expedientes.db.Tramite" />
        <many-to-one name="tipoExpediente" ref="com.educaflow.subsystem.expedientes.db.TipoExpediente" />
        <many-to-one name="expediente" ref="com.educaflow.subsystem.expedientes.db.Expediente" />
    </entity>
</domain-models>