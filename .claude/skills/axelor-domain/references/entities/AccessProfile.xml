<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="security" package="com.educaflow.subsystem.security.db"/>
    <entity name="AccessProfile">
        <string name="name" required="true" namecolumn="true"/>
        <one-to-many name="accessAssignments" ref="com.educaflow.subsystem.security.db.AccessAssignment" mappedBy="accessProfile" title="Acceso"/>
    </entity>
</domain-models>