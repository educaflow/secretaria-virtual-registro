<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="auth" package="com.axelor.auth.db"/>

    <entity name="User">
        <many-to-one name="centroActivo" ref="com.educaflow.subsystem.common.db.Centro" title="Centro Activo" />
        <string name="dni" title="DNI"  />
        <string name="email" title="Correo electrónico" unique="false"/>
        <one-to-many name="centroUsuarios" ref="com.educaflow.subsystem.security.db.CentroUsuario" title=""/>

        <many-to-one name="perfilActivo" ref="com.educaflow.subsystem.security.db.CentroUsuario"
                     transient="true"
                     title="Perfil en centro activo"
        >
            <![CDATA[
                if (centroActivo == null || centroUsuarios == null) {
                    return null;
                }
                return centroUsuarios.stream()
                    .filter(cu -> cu.getCentro().getId().equals(centroActivo.getId()))
                    .findFirst()
                    .orElse(null);
            ]]>
        </many-to-one>


        <string name="nombre" title="Nombre"  />
        <string name="apellidos" title="Apellidos"  />

        <entity-listener class="com.educaflow.subsystem.common.db.repo.UsuarioListener"/>
    </entity>
</domain-models>