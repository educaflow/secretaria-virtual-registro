<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="common" package="com.educaflow.subsystem.security.db"/>
    <entity name="AuthUserRegistry">
        <many-to-one name="centro" ref="com.educaflow.subsystem.common.db.Centro" required="true"/>
        <integer name="curso" title="Curso académico" help="Ejemplo: 2024" required="true"/>
        <string name="dni" title="dni__!!" required="true"/>
        <many-to-one name="tipoUsuario" ref="com.educaflow.subsystem.security.db.TipoUsuario" required="true" title="Tipo de usuario"/>
    </entity>

</domain-models>