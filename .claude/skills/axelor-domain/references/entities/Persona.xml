<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="common" package="com.educaflow.subsystem.common.db"/>
    <entity name="Persona">
        <string name="nombre" title="Nombre"   />
        <string name="apellidos" title="Apellidos"   />
        <string name="dni" title="DNI"   />
        <string name="nia" title="NIA"   />
        <string name="nrp" title="Nº Registro Personal"   />
        <string name="email" title="Correo electrónico"   />
        <string name="dirección" title="Dirección"   />
        <string name="telefono" title="Teléfono"   />
        <many-to-one name="municipio"   title="Municipio"   ref="Municipio" />
        <string name="cp" title="Código Postal"   />
        <string name="nombreApellidos" namecolumn="true" search="nombre,apellidos">
            <![CDATA[
                StringBuilder sb = new StringBuilder();
                if (this.getNombre() != null) {
                    sb.append(this.getNombre());
                }
                if (this.getApellidos() != null) {
                    if (sb.length() > 0) {
                        sb.append(" ");
                    }
                    sb.append(this.getApellidos());
                }
                return sb.toString();
            ]]>
        </string>

        <string name="apellidosNombre" search="apellidos,nombre">
            <![CDATA[
                StringBuilder sb = new StringBuilder();
                if (this.getApellidos() != null) {
                    sb.append(this.getApellidos());
                }
                if (this.getNombre() != null) {
                    if (sb.length() > 0) {
                        sb.append(", ");
                    }
                    sb.append(this.getNombre());
                }
                return sb.toString();
            ]]>
        </string>


    </entity>

</domain-models>