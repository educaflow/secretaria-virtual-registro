<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

    <module name="security" package="com.educaflow.subsystem.security.db"/>
    <entity name="CentroUsuario" extends="com.educaflow.subsystem.security.db.SecurityActor">
        <many-to-one name="centro" ref="com.educaflow.subsystem.common.db.Centro" title="Centro"/>
        <many-to-one name="usuario" ref="com.axelor.auth.db.User" title="Usuario"/>
        <one-to-many name="centroUsuarioTipoUsuario" ref="com.educaflow.subsystem.security.db.CentroUsuarioTipoUsuario" mappedBy="centroUsuario" title=""/>
    </entity>

</domain-models>